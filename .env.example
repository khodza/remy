# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/remy

# Application Configuration
NODE_ENV=development
PORT=3000

# HTTP API (Mini App)
# Secret used to sign short-lived JWTs for the Mini App. Must be at least 32 chars.
JWT_SECRET=change_me_to_a_random_32_char_string_or_longer
JWT_EXPIRES_IN=15m
# Max age of Telegram initData in seconds (default 24h)
INIT_DATA_MAX_AGE_SECONDS=86400
# Comma-separated origin allowlist for CORS (leave empty to allow all in dev)
CORS_ORIGINS=https://web.telegram.org
