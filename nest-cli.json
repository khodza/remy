{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "watchAssets": true,
    "tsConfigPath": "tsconfig.build.json",
    "builder": {
      "type": "swc",
      "options": {
          "ignore": ["**/*.spec.ts", "**/*.test.ts"]
      }
    },
    "typeCheck": true,
    "deleteOutDir": true
  },
  "monorepo": true,
  "projects": {
    "api": {
      "type": "application",
      "entryFile": "/main"
    }
  }
}
